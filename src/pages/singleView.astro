---
import{ Picture }from 'astro:assets';
import diamond from '../assets/images/DIAMOND CAFE.jpg';
import '../styles/global.css'
import Layout from '../layouts/Layout.astro'
---
<Layout>
    <div class="h-screen w-full grid  grid-cols-12 gap-padding bg-theme text-theme text-sm tracking-custom uppercase relative">
        <div class="col-span-2 h-full w-full flex flex-row justify-between pr-padding">
            <a class="opacity-muted">Exit</a>
            <a>Previous</a>
        </div>
        <div class="col-span-10 h-full w-full flex flex-row justify-center items-center overflow-clip">
            <Picture src={diamond} alt="DIAMOND CAFE"  class="w-auto h-full object-cover" />
        </div>
    </div>
</Layout>
