  // ─── Sidebar Preview Functions ─────────────────────────────────────────────

  let activeSidebarPreviewId: string | null = null;
  let activeSidebarListItem: HTMLElement | null = null;

  function showSidebarPreview(projectId: string, listItem: HTMLElement) {
    if (activeSidebarPreviewId === projectId) return;

    // Reset previous list item opacity (but keep current project highlighted)
    if (activeSidebarListItem && activeSidebarListItem.dataset.projectId !== currentProjectId) {
      gsap.to(activeSidebarListItem, { opacity: getMutedOpacity()});
    }

    // Hide previous preview (use cache instead of querySelector)
    if (activeSidebarPreviewId) {
      const prevPreview = previewCache.get(activeSidebarPreviewId);
      if (prevPreview) {
