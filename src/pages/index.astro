        const video = prevPreview.querySelector('mux-player') as HTMLElement & { pause: () => void };
        if (video) video.pause();
      }
    }

    activeSidebarPreviewId = projectId;
    activeSidebarListItem = listItem;

    // Highlight current list item
    gsap.to(listItem, { opacity: 1, duration: 0.4, ease: EASE });

    // Show new preview (use cache)
    const newPreview = previewCache.get(projectId);
    if (newPreview) {
      gsap.to(newPreview, { opacity: 1, duration: 0.01});
      const video = newPreview.querySelector('mux-player') as HTMLElement & { play: () => void };
      if (video) video.play();
    }
  }

  function hideSidebarPreview() {
    // Reset list item opacity (but keep current project highlighted)
    if (activeSidebarListItem && activeSidebarListItem.dataset.projectId !== currentProjectId) {
      gsap.to(activeSidebarListItem, { opacity: getMutedOpacity()});
    }
    activeSidebarListItem = null;

    if (activeSidebarPreviewId) {
      const prevPreview = previewCache.get(activeSidebarPreviewId);
      if (prevPreview) {
        gsap.to(prevPreview, { opacity: 0 });
