---
import Layout from '../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import { MuxPlayer } from '@mux/mux-player-astro';
import { loadQuery } from '../sanity/lib/loadQuery.ts';
import { urlForImage } from '../sanity/lib/url-for-image.ts';
import { sanityClient } from 'sanity:client';

const PROJECTS_QUERY = `*[_type == "project"] | order(index desc) {
 _id,
  name,
  type,
  index,
  thumbnail {
      ...,
      asset-> {
        _id,
        url,
        metadata {
          dimensions,
          lqip
        }
      }
    },
  imageGallery[] {
      _key,
      asset-> {
        _id,
        url,
        metadata {
          dimensions,
          lqip
        }
      }
    },
  muxID,
}`;

const { data: projects } = await loadQuery({ query: PROJECTS_QUERY });

const ROW_SIZE = 5;

// Chunk into rows of ROW_SIZE
const rows = Array.from({ length: Math.ceil(projects.length / ROW_SIZE) }, (_, i) =>
  projects.slice(i * ROW_SIZE, i * ROW_SIZE + ROW_SIZE)
);

// aspect is h/w — portrait 2/3 = 1.5, landscape 16/9 ≈ 0.5625
function getAspect(project: (typeof projects)[number]): number {
  return project.muxID && !project.thumbnail?.asset ? 9 / 16 : 7 / 5;
}

// Pre-compute all image URLs for client-side use
const projectsWithUrls = projects.map(project => ({
  ...project,
  thumbnailUrl: project.thumbnail?.asset ? `${urlForImage(project.thumbnail).url()}?auto=format` : null,
  galleryUrls: project.imageGallery?.filter((img: any) => img?.asset).map((img: any) => ({
    url: `${urlForImage(img).url()}?auto=format`,
    _key: img._key
  })) || []
}));
---

<style>
  /* GPU optimization hints for frequently animated elements */
  .gallery-row-wrapper {
    will-change: transform;
    contain: layout style;
  }
  .gallery-item {
    will-change: flex-grow;
    contain: layout style;
  }
  .gallery-item-cover {
    will-change: transform;
  }
  .preview-item {
    will-change: opacity;
  }
  /* Reduce paint areas */
  #gallery-container {
    contain: layout style;
  }
</style>

<Layout title="Justin Abernethy">
  <main class="p-padding bg-theme text-theme">
    <section class="relative">
      {projects.length === 0 && <p class="text-gray-400">No projects found.</p>}

      <!-- Gallery Container -->
      <div id="gallery-container" class="flex flex-col gap-0">
        {
          rows.map((row, rowIndex) => (
            <div class="gallery-row-wrapper relative" data-wrapper={rowIndex}>
              <div
                class="gallery-row absolute inset-x-0 bottom-0 flex gap-0 items-end"
                data-row={rowIndex}
              >
                {row.map((project, projectIndex) => {
                  const aspect = getAspect(project);
                  const globalIndex = rowIndex * ROW_SIZE + projectIndex;
                  return (
                    <div
                      class="gallery-item flex flex-col gap-padding min-w-0 px-padding-half cursor-pointer relative overflow-hidden"
                      style="flex: 1 1 0%"
                      data-aspect={aspect}
                      data-row={rowIndex}
                      data-global-index={globalIndex}
                      data-project-id={project._id}
                    >
                      {/* Cover overlay for animation */}
                      <div class="gallery-item-cover absolute -inset-1 bg-theme z-10 pointer-events-none" style="transform: translateY(100%)"></div>

                      {project.muxID && !project.thumbnail?.asset ? (
                        <MuxPlayer
                          playbackId={project.muxID}
                          class="item-media w-full object-cover aspect-16/9"
                          style={{ '--controls': 'none' }}
                          muted
                          loop
                          data-flip-id={`media-${project._id}`}
                        />
                      ) : (
                        <img
                          src={`${urlForImage(project.thumbnail).url()}?auto=format`}
                          alt={project.name}
                          class="item-media w-full object-cover"
                          style="aspect-ratio: 5/7"
                          data-flip-id={`media-${project._id}`}
                        />
                      )}
                      <div id="item-name-type" class="item-name-type flex flex-row justify-between w-full relative overflow-clip font-medium -mt-0.5 pb-padding">
                        <div class="absolute z-0 mt-0 h-full flex flex-col gap-0 project-title">
                          <h3 class="text-sm leading-[100%] tracking-custom whitespace-nowrap">{project.name}</h3>
                        </div>
                        <div class="title-fade-overlay absolute inset-0 h-full w-full z-1 pointer-events-none opacity-0 gradient-fade"></div>
                        <div class="flex flex-col gap-0 items-end grow z-2">
                          <p class="text-sm leading-[100%] tracking-custom flex">{project.index}</p>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          ))
        }
      </div>

      <!-- Project Detail Section (hidden initially, in document flow) -->
      <div id="project-detail" class="hidden z-20">
        <div class="w-full flex pb-padding">
          <div class="grid grid-cols-10 gap-padding w-full">
            <!-- Left Sidebar -->
            <div class="col-span-2 flex flex-col h-full min-h-screen">
              <div class="sticky top-0 h-screen min-h-200 w-full flex flex-col justify-end pb-padding">
                <!-- Project name -->
                <div class="flex flex-col grow justify-end pb-padding text-sm uppercase tracking-custom leading-[105%] font-medium">
                  <h2 id="detail-project-name"></h2>
                  <h2 id="detail-project-type" class="opacity-muted"></h2>
                </div>

                <!-- Preview container -->
                <div class="project-preview w-[75%] mb-padding">
                  <div class="relative w-full" style="aspect-ratio: 4/5">
                    <div class="grid absolute inset-0" id="detail-preview-grid">
                      {projectsWithUrls.map((project) => (
                        <div
                          class="preview-item opacity-0 col-start-1 row-start-1 flex items-end"
                          data-preview-id={project._id}
                        >
                          {project.muxID && !project.thumbnailUrl ? (
                            <MuxPlayer
                              playbackId={project.muxID}
                              class="w-full object-cover aspect-video"
                              style={{ '--controls': 'none' }}
                              muted
                              loop
                            />
                          ) : project.thumbnailUrl ? (
                            <img
                              src={project.thumbnailUrl}
                              alt={project.name}
                              class="w-full object-cover"
                              style="aspect-ratio: 4/5"
                            />
                          ) : null}
                        </div>
                      ))}
                    </div>
                  </div>
                </div>

                <!-- Project list -->
                <div id="project-list-container" class="project-list-container">
                  <div class="project-list flex flex-col justify-end gap-0 text-sm uppercase tracking-custom leading-[115%] font-medium">
                    {projectsWithUrls.map((project) => (
                      <div
                        class="detail-list-item flex flex-row gap-padding cursor-pointer opacity-muted"
                        data-project-id={project._id}
                      >
                        <p class="min-w-4.5">{String(project.index).padStart(3, '0')}</p>
                        <p>{project.name}</p>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <!-- Right Content - Image Gallery -->
            <div class="col-span-8 flex flex-col gap-padding">
              <div id="detail-image-gallery" class="grid grid-cols-2 grid-flow-row gap-padding w-full">
                <!-- Images will be populated dynamically -->
              </div>
            </div>
          </div>
        </div>
      </div>

      <div id="single-view-overlay" class="fixed inset-0 z-[10000] bg-theme hidden opacity-0 pointer-events-none transition-opacity duration-300">
        <div class="h-screen w-full grid! grid-cols-20 gap-padding bg-theme text-theme text-sm tracking-custom uppercase relative px-padding">

          <!-- Left Controls (initially hidden) -->
          <div class="col-span-3 h-full w-full flex flex-row items-center justify-between pr-padding">
            <a id="overlay-exit" class="overlay-nav opacity-muted hover:opacity-100 cursor-pointer ">Exit</a>
            <a id="overlay-prev" class="overlay-nav opacity-100 cursor-pointer hover:opacity-muted">Previous</a>
          </div>

          <!-- Center Media (initially hidden/scaled) -->
          <div class="col-span-14 h-screen w-full flex flex-row justify-center items-center overflow-clip">
            <div id="overlay-media-container" class="w-full h-full flex items-center justify-center opacity-0">
              <!-- Media injected via JS -->
            </div>
          </div>

          <!-- Right Controls (initially hidden) -->
          <div class="col-span-3 col-start-18 h-full w-full flex flex-row items-center justify-between pl-padding">
            <a id="overlay-next" class="overlay-nav opacity-100 cursor-pointer hover:opacity-muted">Next</a>
            <p id="overlay-pagination" class="opacity-100 overlay-nav">1/5</p>
          </div>
        </div>
      </div>
    </section>
  </main>

</Layout>

<!-- Pass project data to client -->
<script define:vars={{ projectsWithUrls, ROW_SIZE }}>
  window.__PROJECTS_DATA__ = projectsWithUrls;
  window.__ROW_SIZE__ = ROW_SIZE;
</script>

<script>
  import { overwrite } from 'astro:schema';
import gsap from 'gsap';


  // ─── Constants ─────────────────────────────────────────────────────────────
  const FALLOFF = 0.8;
  const ITEM_GAP_PX = 8;
  const DURATION = 0.5;
  const DURATION_ALT = 0.5;
  const EASE = 'power3.out';
  const COVER_DURATION = 1.2;
  const COVER_STAGGER_WINDOW = 0.8; // Total time window for all staggers
  const COVER_STAGGER_CURVE = 1.5; // Power curve (<1 = ramps down, items bunch at end)
  const FLIP_DURATION = 0.6;
  const SETTLE_DURATION = 0.6; // Duration for hover animations to settle before capturing

  const MOVE_DURATION = 1.2;
  const MOVE_DELAY = 0.7;

  const VERTICAL_THRESHOLD = 0.9;
  const INTENSITY_MULTIPLIER = 0.8;
  const CURVE_POWER = 1;
  // Helper to get theme-aware muted opacity
  function getMutedOpacity(): number {
    return document.documentElement.classList.contains('dark') ? 0.2 : 0.3;
  }

  // ─── Performance Utilities ─────────────────────────────────────────────────
  function throttleRAF<T extends (...args: any[]) => void>(fn: T): T {
    let rafId: number | null = null;
    let lastArgs: Parameters<T> | null = null;

    const throttled = (...args: Parameters<T>) => {
      lastArgs = args;
      if (rafId === null) {
        rafId = requestAnimationFrame(() => {
          rafId = null;
          if (lastArgs) fn(...lastArgs);
        });
      }
    };

    return throttled as T;
  }

  // ─── DOM Elements ──────────────────────────────────────────────────────────
  const container = document.getElementById('gallery-container')!;
  const projectDetail = document.getElementById('project-detail')!;
  const projectListContainer = document.getElementById('project-list-container')!;
  const detailProjectName = document.getElementById('detail-project-name')!;
  const detailProjectType = document.getElementById('detail-project-type')!;
  const detailImageGallery = document.getElementById('detail-image-gallery');

  // Early exit if essential elements don't exist
  if (!container || !projectDetail || !detailProjectName || !detailProjectType || !detailImageGallery) {
    console.error('Missing essential DOM elements');
  } else {
  // Main script wrapped in else block to prevent execution when elements are missing

  const allWrappers = [...container.querySelectorAll<HTMLElement>('.gallery-row-wrapper')];
  const allRows = [...container.querySelectorAll<HTMLElement>('.gallery-row')];
  const allItems = [...container.querySelectorAll<HTMLElement>('.gallery-item')];

  // ─── State ─────────────────────────────────────────────────────────────────
  let activeRowIndex: number = -1;
  let isProjectOpen = false;
  let isAnimating = false; // Block hover updates during open/close animations
  let currentProjectId: string | null = null;
  let clickedRowIndex: number = -1;
  let savedMaxDelta: number = 0;

  const fadedEdge = new Map<HTMLElement, HTMLElement[] | null>();
  let lastMouseX = 0;
  let lastMouseY = 0;

  // ─── Cached Data ───────────────────────────────────────────────────────────
  // Cache items per row to avoid repeated DOM queries
  const rowItemsCache = new Map<HTMLElement, HTMLElement[]>();
  const itemAspectsCache = new Map<HTMLElement, number>();

  // Pre-cache row items and aspects
  allRows.forEach(row => {
    const items = [...row.querySelectorAll<HTMLElement>('.gallery-item')];
    rowItemsCache.set(row, items);
    items.forEach(item => {
      itemAspectsCache.set(item, parseFloat(item.dataset.aspect || '1'));
    });
  });

  // Cache preview elements for sidebar
  const previewCache = new Map<string, HTMLElement>();
  document.querySelectorAll<HTMLElement>('#detail-preview-grid [data-preview-id]').forEach(el => {
    const id = el.dataset.previewId;
    if (id) previewCache.set(id, el);
  });

  // Track last animated state to avoid redundant animations
  let lastTargetRowIndex = -1;
  let lastWeightsKey = '';

  // Get project data from window
  const projectsData = (window as any).__PROJECTS_DATA__ as any[] || [];
  const ROW_SIZE = (window as any).__ROW_SIZE__ as number || 5;

  // ─── Project Detail Functions ──────────────────────────────────────────────

  function getProjectById(id: string) {
    return projectsData.find(p => p._id === id);
  }

  function populateProjectDetail(project: any) {
    // Set project name and type
    detailProjectName.textContent = project.name;
    detailProjectType.textContent = project.type || '';

    // Clear existing gallery
    detailImageGallery.innerHTML = '';

    // Add first image slot (will be populated by FLIP animation target)
    const firstSlot = document.createElement('div');
    firstSlot.className = 'col-span-1 w-full overflow-visible';
    firstSlot.id = 'detail-first-image';

    attachDetailGalleryListeners();

    if (project.muxID && !project.thumbnailUrl) {
      firstSlot.innerHTML = `
        <mux-player
          playback-id="${project.muxID}"
          class="w-full object-cover aspect-video"
          style="--controls: none"
          muted
          loop
          data-flip-id="media-${project._id}"
        ></mux-player>
      `;
    } else if (project.thumbnailUrl) {
      firstSlot.innerHTML = `
        <img
          src="${project.thumbnailUrl}"
          alt="${project.name}"
          class="w-full h-full object-cover"
          style="aspect-ratio: 5/7"
          data-flip-id="media-${project._id}"
        />
      `;
    }
    detailImageGallery.appendChild(firstSlot);

    // Add gallery images with cover overlays for reveal animation
    if (project.galleryUrls && project.galleryUrls.length > 0) {
      project.galleryUrls.forEach((img: any) => {
        const slot = document.createElement('div');
        slot.className = 'col-span-1 w-full overflow-hidden relative';
        slot.innerHTML = `
          <img
            src="${img.url}"
            alt="${project.name}"
            class="w-full h-full object-cover"
            style="aspect-ratio: 5/7"
          />
          <div class="gallery-image-cover absolute inset-0 bg-theme z-10 pointer-events-none"></div>
        `;
        detailImageGallery.appendChild(slot);
      });
    }

    // Update active state in sidebar list
    document.querySelectorAll('.detail-list-item').forEach(item => {
      const itemId = (item as HTMLElement).dataset.projectId;
      if (itemId === project._id) {
        gsap.to(item, { opacity: 1});
      } else {
        gsap.to(item, { opacity: getMutedOpacity()});
      }
    });
    attachDetailGalleryListeners();
  }

  function openProject(projectId: string, clickedItem: HTMLElement) {
    if (isProjectOpen || isAnimating) return;

    const project = getProjectById(projectId);
    if (!project) return;

    isProjectOpen = true;
    isAnimating = true; // Block hover updates during animation
    currentProjectId = projectId;
    clickedRowIndex = parseInt(clickedItem.dataset.row || '0');

    // Populate project detail (but keep it hidden for now)
    populateProjectDetail(project);

    // ═══════════════════════════════════════════════════════════════════════════
    // STAGE 0: Settle hover animations before capturing position
    // ═══════════════════════════════════════════════════════════════════════════

    // Create a timeline to settle all hover animations
    const settleTl = gsap.timeline({
      onComplete: () => {
        // Now that everything is settled, capture position and start the main animation
        startOpenAnimation(projectId, clickedItem, project);
      }
    });

    // Animate all items back to rest state (flexGrow: 1)
    allRows.forEach(row => {
      row.querySelectorAll<HTMLElement>('.gallery-item').forEach((item) => {
        settleTl.to(item, {
          flexGrow: 1,
          duration: SETTLE_DURATION,
          ease: 'power2.out',
          overwrite: true
        }, 0);
      });
    });

    // Animate all wrappers back to rest state (y: 0)
    allWrappers.forEach((wrapper) => {
      settleTl.to(wrapper, {
        y: 0,
        duration: SETTLE_DURATION,
        ease: 'power2.out',
        overwrite: true
      }, 0);
    });
  }

  function startOpenAnimation(projectId: string, clickedItem: HTMLElement, project: any) {
    // Disable sidebar pointer events during animation
    projectListContainer.style.pointerEvents = 'none';

    // Get clicked item's media element and capture its position AFTER settling
    const clickedMedia = clickedItem.querySelector('.item-media') as HTMLElement;
    const clickedRect = clickedMedia.getBoundingClientRect();
    const clickedCaption = clickedItem.querySelector('.item-name-type') as HTMLElement;

    // ═══════════════════════════════════════════════════════════════════════════
    // STAGE 1: Create fixed clone, animate covers on other items
    // ═══════════════════════════════════════════════════════════════════════════

    // Create a fixed-position clone of the clicked media
    // This stays in place visually while we manipulate the DOM and scroll

    if (clickedCaption) clickedCaption.style.visibility = 'hidden';
    // Hide the original clicked media (clone is now visible in its place)


    const clone = clickedMedia.cloneNode(true) as HTMLElement;
    clone.id = 'transition-clone';
    clone.style.cssText = `
      position: fixed;
      top: ${clickedRect.top}px;
      left: ${clickedRect.left}px;
      width: ${clickedRect.width}px;
      height: ${clickedRect.height}px;
      z-index: 9999;
      pointer-events: none;
      object-fit: cover;
    `;
    document.body.appendChild(clone);
    clickedMedia.style.visibility = 'hidden';

    // Get ALL items except clicked one to cover during Stage 1
    // Disable pointer events on clicked item to prevent hover interference during animation
    clickedItem.style.pointerEvents = 'none';

    const clickedGlobalIndex = parseInt(clickedItem.dataset.globalIndex || '0');

    // Only animate items that are visible in the viewport
    const viewportHeight = window.innerHeight;
    const viewportTop = 0;
    const viewportBottom = viewportHeight;

    const itemsToHide = allItems
      .filter(item => {
        const rect = item.getBoundingClientRect();
        // Item is visible if it overlaps with the viewport
        return rect.bottom > viewportTop && rect.top < viewportBottom;
      })
      .map(item => ({
        item,
        distance: Math.abs(parseInt(item.dataset.globalIndex || '0') - clickedGlobalIndex)
      }))
      .sort(() => Math.random() - 0.5);

    // Animate covers on other items (exponentially decreasing stagger)
    const tl = gsap.timeline();
    const totalItems = itemsToHide.length;

    itemsToHide.forEach(({ item }, index) => {
      const cover = item.querySelector('.gallery-item-cover') as HTMLElement;
      if (!cover) return;

      // Get the actual pixel height of the cover for precise animation
      const coverHeight = cover.offsetHeight;

      // Immediately set cover to starting position (below the item)
      gsap.set(cover, { y: coverHeight, immediateRender: true, overwrite: true });

      // Calculate exponential stagger delay (ramps down so items bunch together at end)
      // Using power curve: delay = window * (normalizedIndex ^ curve)
      const normalizedIndex = totalItems > 1 ? index / (totalItems - 1) : 0;
      const staggerDelay = COVER_STAGGER_WINDOW * Math.pow(normalizedIndex, COVER_STAGGER_CURVE);

      // Animate cover sliding up to cover the image
      tl.to(cover, {
        y: 0,
        duration: COVER_DURATION,
        ease: "power3.in",
        overwrite: 'auto'
      }, staggerDelay);
    });

    // ═══════════════════════════════════════════════════════════════════════════
    // STAGE 2: After covers complete, set up layout and animate clone to target
    // ═══════════════════════════════════════════════════════════════════════════

    tl.call(() => {
      // Check if clicked row is the last row
      const isLastRow = clickedRowIndex === allWrappers.length - 1;

      // Hide rows up to and including clicked row (unless it's the last row - then show all)
      if (!isLastRow) {
        for (let i = 0; i <= clickedRowIndex; i++) {
          allWrappers[i].style.display = 'none';
        }
      }

      // Remove covers from visible rows
      // If last row clicked, remove covers from ALL rows; otherwise only rows below
      const firstVisibleRow = isLastRow ? 0 : clickedRowIndex + 1;
      for (let i = firstVisibleRow; i < allWrappers.length; i++) {
        allWrappers[i].querySelectorAll('.gallery-item-cover').forEach(cover => {
          gsap.set(cover, { y: '100%' });
        });
      }

      // Calculate the same spacing used for hover (maxDelta + 20)
      const deltas = allWrappers.map((_, i) => calcMaxDelta(i)).filter(d => isFinite(d) && !isNaN(d));
      savedMaxDelta = deltas.length > 0 ? Math.max(...deltas) : 0;

      // Add margin-top to container to create spacing below project detail
      gsap.set(container, { y: 0, marginTop: savedMaxDelta*2});

      // Move project detail BEFORE the gallery container
      container.parentElement?.insertBefore(projectDetail, container);

      // Show project detail with fade-in

      gsap.set(projectListContainer, { opacity: 0 });
      projectDetail.classList.remove('hidden');

      // Instantly scroll to top - INVISIBLE because clone is fixed in viewport
      window.scrollTo(0, 0);


      // Force layout reflow so target element has computed dimensions
      void projectDetail.offsetHeight;

      // Get target media position (now that we're scrolled to top, this is accurate)
      const targetMedia = document.querySelector('#detail-first-image img, #detail-first-image mux-player') as HTMLElement;

      if (targetMedia) {
        // Don't hide target - let clone (z-index 9999) sit on top of it
        // Target is visible underneath, so when clone is removed, there's no flash

        const targetRect = targetMedia.getBoundingClientRect();
        // Hide target initially (clone will animate to its position)
        targetMedia.style.visibility = 'hidden';
        // Animation parameters


        // Calculate scale factors
        const scaleX = clickedRect.width / targetRect.width;
        const scaleY = clickedRect.height / targetRect.height;

        // Animate clone from its current fixed position to target position
        gsap.to(clone, {
          top: targetRect.top,
          left: targetRect.left,
          width: targetRect.width,
          height: targetRect.height,
          delay: MOVE_DELAY,
          duration: MOVE_DURATION,
          ease: "power3.out",
          onComplete: () => {
            // Just remove the clone - target is already visible underneath
            clone.remove();
            targetMedia.style.visibility = 'visible';
          }
        });



        // ═══════════════════════════════════════════════════════════════════════
        // STAGE 3: Reveal project detail elements and remove covers from rows below
        // ═══════════════════════════════════════════════════════════════════════

        // Reveal gallery images by sliding covers up
        const galleryCovers = detailImageGallery.querySelectorAll('.gallery-image-cover');
        gsap.fromTo(galleryCovers,
          { y: 0 },
          { y: '-100%', duration: 1.2, ease: "power3.out", stagger: 0.2, delay: MOVE_DURATION +0.4}
        );

        // Remove covers from rows below (they were never covered, but ensure they're revealed)
        for (let i = clickedRowIndex + 1; i < allWrappers.length; i++) {
          allWrappers[i].querySelectorAll('.gallery-item-cover').forEach(cover => {
            gsap.set(cover, { y: '100%' });
          });
        }

        gsap.fromTo(detailProjectName, { opacity: 0 }, { opacity: 1, duration: 2, delay: 1, ease: "power2.out"});
        gsap.fromTo(detailProjectType, { opacity: 0 }, { opacity: getMutedOpacity(), duration: 2, delay: 1.1, ease: "power2.out"});
        gsap.fromTo(projectListContainer, { opacity: 0 }, { opacity: 1, duration: 2, delay: 1.2, ease: "power2.out", onComplete: () => {
          // Re-enable sidebar pointer events after animation completes
           projectListContainer.style.pointerEvents = 'auto';
        }});
        // Re-enable hover updates after animation completes
        isAnimating = false;

        // Setup scroll observer AFTER all DOM changes are complete
        setupScrollObserver();

      } else {
        // Fallback: just remove clone
        clone.remove();
        isAnimating = false;
        setupScrollObserver();

      }
    });
  }

  function closeProject(instant = true) {
    if (!isProjectOpen) return;

    // ═══════════════════════════════════════════════════════════════════════════
    // SEAMLESS CLOSE: Keep visible content stable, reset everything above viewport
    // ═══════════════════════════════════════════════════════════════════════════

    // Stop Lenis to prevent smooth scroll interference during close
    const lenis = (window as any).lenis;
    if (lenis) lenis.stop();

    // Find the first visible row (the one the user is looking at)
    // If last row was clicked, all rows are visible starting from 0
    const isLastRow = clickedRowIndex === allWrappers.length - 1;
    const firstVisibleIndex = isLastRow ? 0 : clickedRowIndex + 1;
    const firstVisibleWrapper = allWrappers[firstVisibleIndex];

    // Capture the current visual position of the first visible row
    const anchorRect = firstVisibleWrapper?.getBoundingClientRect();
    const anchorTop = anchorRect?.top ?? 0;

    // Now do all the resets
    isProjectOpen = false;
    isAnimating = false;
    currentProjectId = null;

    // Clean up scroll observer
    cleanupScrollObserver();

    // Hide project detail instantly (it's above viewport anyway)
    projectDetail.classList.add('hidden');

    // Move project detail back to after the gallery container
    container.parentElement?.insertBefore(projectDetail, container.nextSibling);

    // Show all rows and reset visibility
    // Reset only previously hidden rows (0 to clickedRowIndex) to avoid affecting visible content
    const hiddenRowEnd = firstVisibleIndex;

    allWrappers.forEach((wrapper, i) => {
      wrapper.style.display = '';
      wrapper.style.visibility = '';

      // Reset y transform for ALL wrappers to ensure consistent state
      gsap.set(wrapper, { y: 0 });
    });

    // Reset flexGrow only for previously hidden rows
    for (let i = 0; i < hiddenRowEnd; i++) {
      allRows[i].querySelectorAll<HTMLElement>('.gallery-item').forEach(item => {
        gsap.set(item, { flexGrow: 1 });
      });
    }

    // Reset all covers instantly
    allItems.forEach(item => {
      const cover = item.querySelector('.gallery-item-cover') as HTMLElement;
      gsap.set(cover, { y: '100%' });
    });

    // Reset container margin and restore original y offset for hover
    // Use savedMaxDelta to ensure consistency with open state
    gsap.set(container, { marginTop: 0, y: savedMaxDelta + 20 });

    // Reset clicked item visibility and pointer-events (including media and caption)
    allItems.forEach(item => {
      item.style.visibility = '';
      item.style.pointerEvents = '';
      const media = item.querySelector('.item-media') as HTMLElement;
      if (media) media.style.visibility = '';
      const caption = item.querySelector('.item-name-type') as HTMLElement;
      if (caption) caption.style.visibility = '';
    });

    // Reset hover state (don't call init() - it would reset flexGrow and recalculate heights causing visual jumps)
    clickedRowIndex = -1;
    activeRowIndex = -1;

    // ═══════════════════════════════════════════════════════════════════════════
    // SCROLL COMPENSATION: Adjust scroll so visible content stays in place
    // ═══════════════════════════════════════════════════════════════════════════

    if (firstVisibleWrapper) {
      // Force layout recalculation
      void firstVisibleWrapper.offsetHeight;

      // Get the new position after all resets
      const newRect = firstVisibleWrapper.getBoundingClientRect();
      const newTop = newRect.top;

      // Calculate how much the content shifted
      const shift = newTop - anchorTop;

      // Compensate by adjusting scroll position (instant, no animation)
      if (Math.abs(shift) > 1) {
        // Use native scroll since Lenis is stopped
        window.scrollTo({ top: window.scrollY + shift, behavior: 'instant' });
      }
    }

    // Resume Lenis after scroll compensation
    if (lenis) {
      // Small delay to ensure DOM has settled before resuming smooth scroll
      requestAnimationFrame(() => {
        lenis.start();
      });
    }
  }

  function transitionToProject(newProjectId: string) {
    if (newProjectId === currentProjectId) return;

    const project = getProjectById(newProjectId);
    if (!project) return;

    currentProjectId = newProjectId;

    // Fade out current gallery
    gsap.to(detailImageGallery.children, {
      opacity: 0,
      duration: DURATION_ALT * 0.5,
      ease: EASE,
      onComplete: () => {
        // Populate new project
        populateProjectDetail(project);

        // Fade in new gallery

        gsap.fromTo(detailImageGallery.children,
          { opacity: 0, y: 10 },
          { opacity: 1, y: 0, duration: DURATION, ease: EASE, stagger: 0.03 }
        );
        const galleryCovers = detailImageGallery.querySelectorAll('.gallery-image-cover');
        gsap.fromTo(galleryCovers,
          { y: 0 },
          { y: '-100%', duration: 1.2, ease: "power3.out", stagger: 0.2, delay: DURATION/2 }
        );
      }
    });
  }

  // ─── Scroll Observer ───────────────────────────────────────────────────────

  let scrollObserver: IntersectionObserver | null = null;
  let scrollHandler: (() => void) | null = null;

  function setupScrollObserver() {
    if (scrollObserver) {
      scrollObserver.disconnect();
    }
    if (scrollHandler) {
      window.removeEventListener('scroll', scrollHandler);
    }

    // Get the first visible row wrapper
    // If last row was clicked, all rows are visible starting from 0
    const isLastRow = clickedRowIndex === allWrappers.length - 1;
    const firstVisibleIndex = isLastRow ? 0 : clickedRowIndex + 1;
    const firstVisibleWrapper = allWrappers[firstVisibleIndex];

    // If no visible rows below, no need for observer
    if (!firstVisibleWrapper) return;

    // IntersectionObserver for primary detection
    // Observe the first visible row wrapper for more reliable detection
    scrollObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        // Close when the bottom of the first visible row reaches the top of the viewport
        if (isProjectOpen && entry.boundingClientRect.top <= 0) {
          closeProject(true);
        }
      });
    }, {
      threshold: [0, 0.1, 0.25, 0.5], // Multiple thresholds for better detection
      rootMargin: '0px 0px 0px 0px'
    });

    scrollObserver.observe(firstVisibleWrapper);

    // Scroll listener as backup (checks on every scroll)
    scrollHandler = () => {
      if (!isProjectOpen) return;
      // Close when the bottom of the first visible row reaches the top of the viewport
      const wrapperRect = firstVisibleWrapper.getBoundingClientRect();
      if (wrapperRect.bottom <= 0) {
        closeProject(true);
      }
    };

    window.addEventListener('scroll', scrollHandler, { passive: true });
  }

  function cleanupScrollObserver() {
    if (scrollObserver) {
      scrollObserver.disconnect();
      scrollObserver = null;
    }
    if (scrollHandler) {
      window.removeEventListener('scroll', scrollHandler);
      scrollHandler = null;
    }
  }

