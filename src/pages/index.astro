  window.addEventListener('scroll', handleScroll, { passive: true });

  function resetAll() {
    if (activeRowIndex === -1) return;

    // Determine the first visible index for reset logic (handles last-row-open case)
    const firstVisibleIndex = isProjectOpen && clickedRowIndex >= allWrappers.length - 1 ? 0 : (isProjectOpen ? clickedRowIndex + 1 : 0);
    allRows.forEach((row, i) => {
      // Skip hidden rows when project is open
      if (isProjectOpen && i < firstVisibleIndex) return;
      resetRow(row);
    });
    activeRowIndex = -1;

    allWrappers.forEach((wrp, i) => {
      // Skip hidden wrappers when project is open
      if (isProjectOpen && i < firstVisibleIndex) return;
      gsap.to(wrp, { y: 0, duration: DURATION, ease: EASE, overwrite: 'auto' });
    });
  }

  function updateHoverAtPoint(clientX: number, clientY: number) {
    // Skip hover updates during animation
    if (allRows.length === 0 || isAnimating) return;

    const cRect = container.getBoundingClientRect();

    if (clientX < cRect.left - 20 || clientX > cRect.right + 20) {
      resetAll();
      return;
    }

    // When project is open, check if mouse is within visible rows bounds
    if (isProjectOpen && clickedRowIndex >= 0) {
      // If the opened project is in the last row, treat all rows as visible (start at 0)
      const firstVisibleIndexForHover = clickedRowIndex >= allWrappers.length - 1 ? 0 : clickedRowIndex + 1;
      const firstVisibleWrapper = allWrappers[firstVisibleIndexForHover];
      if (firstVisibleWrapper) {
        const visibleTop = firstVisibleWrapper.getBoundingClientRect().top;
        const visibleBottom = allWrappers[allWrappers.length - 1].getBoundingClientRect().bottom;

        // If mouse is above the visible rows (e.g., over project detail), reset hover
        if (clientY < visibleTop - 40 || clientY > visibleBottom + 40) {
          resetAll();
          return;
        }
      }
    }

    let hoveredIndex = -1;
    let minDistance = Infinity;
    let closestIndex = -1;

    // Determine the first visible row index for iteration (handles last-row-open case)
    const firstVisibleIndexForLoop = isProjectOpen && clickedRowIndex >= allWrappers.length - 1 ? 0 : (isProjectOpen ? clickedRowIndex + 1 : 0);
    for (let i = 0; i < allRows.length; i++) {
      // Skip rows that are above the visible start when project is open
      if (isProjectOpen && i < firstVisibleIndexForLoop) continue;

      const row = allRows[i];
      const rect = row.getBoundingClientRect();

      if (clientY >= rect.top && clientY <= rect.bottom) {
        hoveredIndex = i;
      }

      let dist = 0;
      if (clientY < rect.top) dist = rect.top - clientY;
      else if (clientY > rect.bottom) dist = clientY - rect.bottom;

      if (dist < minDistance) {
        minDistance = dist;
        closestIndex = i;
      }
    }

    const targetRowIndex = hoveredIndex !== -1 ? hoveredIndex : closestIndex;

    // If no valid row found, or target is in hidden rows when project is open
    // Determine the first visible index for validation (handles last-row-open case)
    const firstVisibleIndexForValidation = isProjectOpen ? (clickedRowIndex >= allWrappers.length - 1 ? 0 : clickedRowIndex + 1) : 0;
    if (targetRowIndex === -1 || (isProjectOpen && targetRowIndex < firstVisibleIndexForValidation)) {
      resetAll();
      return;
    }

    // If not directly hovering a row and too far from the closest one, reset
    // This handles when mouse is over project detail (above visible rows)
    if (hoveredIndex === -1 && minDistance > 100) {
      resetAll();
      return;
    }

    // Use correct first/last visible wrappers when project is open
    // If the opened project is in the last row, treat all rows as visible (start at 0)
    const firstVisibleIndex = isProjectOpen ? (clickedRowIndex >= allWrappers.length - 1 ? 0 : clickedRowIndex + 1) : 0;
    const firstWrapper = allWrappers[firstVisibleIndex];
    const lastWrapper = allWrappers[allWrappers.length - 1];

    // If no visible wrappers, reset and return
    if (!firstWrapper) {
      resetAll();
      return;
    }

    const staticTopBounds = firstWrapper.getBoundingClientRect().top - (gsap.getProperty(firstWrapper, 'y') as number || 0);
    const staticBottomBounds = lastWrapper.getBoundingClientRect().bottom - (gsap.getProperty(lastWrapper, 'y') as number || 0);
    const visualTop = allRows[firstVisibleIndex].getBoundingClientRect().top;
    const visualBottom = allRows[allRows.length - 1].getBoundingClientRect().bottom;

    const effectiveTop = Math.min(visualTop, staticTopBounds);
    const effectiveBottom = Math.max(visualBottom, staticBottomBounds);

    if (clientY < effectiveTop - 40 || clientY > effectiveBottom + 40) {
       resetAll();
       return;
    }

    const targetRow = allRows[targetRowIndex];
    const items = rowItemsCache.get(targetRow) || [];
    const n = items.length;

    const wrapper = allWrappers[targetRowIndex];
    const currentY = gsap.getProperty(wrapper, 'y') as number || 0;
    const staticTop = wrapper.getBoundingClientRect().top - currentY;
    const staticHeight = wrapper.offsetHeight;

    let cursorYNorm = (clientY - staticTop) / staticHeight;
    cursorYNorm = Math.max(0, Math.min(1, cursorYNorm));



    // Factor for row below (when cursor near bottom)
    let verticalFactor = 0;
    if (cursorYNorm > VERTICAL_THRESHOLD) {
      let progress = (cursorYNorm - VERTICAL_THRESHOLD) / (1 - VERTICAL_THRESHOLD);
      verticalFactor = Math.pow(progress, CURVE_POWER) * INTENSITY_MULTIPLIER;
      verticalFactor = Math.min(1, verticalFactor);
    }

    // Factor for row above (when cursor near top)
    let aboveVerticalFactor = 0;
    const ABOVE_THRESHOLD = 0.05; // 0.25 when VERTICAL_THRESHOLD is 0.75
    if (cursorYNorm < ABOVE_THRESHOLD) {
      let progress = (ABOVE_THRESHOLD - cursorYNorm) / ABOVE_THRESHOLD;
      aboveVerticalFactor = Math.pow(progress, CURVE_POWER) * INTENSITY_MULTIPLIER;
      aboveVerticalFactor = Math.min(1, aboveVerticalFactor);
    }

    const rect = targetRow.getBoundingClientRect();
    const cursorPos = ((clientX - rect.left) / rect.width) * n;
    const horizontalWeights = getWeights(cursorPos, n);

    const nextRowIndex = targetRowIndex + 1;
    const hasNextRow = nextRowIndex < allRows.length;

    const prevRowIndex = targetRowIndex - 1;
    const hasPrevRow = prevRowIndex >= (isProjectOpen ? clickedRowIndex + 1 : 0);

    allRows.forEach((row, i) => {
      if (i !== targetRowIndex && i !== nextRowIndex && i !== prevRowIndex) {
        resetRow(row);
      }
    });

    allRows.forEach((row, i) => {
      gsap.set(row, { zIndex: (i === targetRowIndex || i === nextRowIndex || i === prevRowIndex) ? 10 : 'auto' });
    });

    animateItems(targetRow, horizontalWeights);
    updateEdgeFade(targetRow, { clientX, clientY } as MouseEvent, n);

    if (hasNextRow) {
      const nextRow = allRows[nextRowIndex];
      const nextWeights = horizontalWeights.map(w => 1 + (w - 1) * verticalFactor);
      animateItems(nextRow, nextWeights);
    }

    if (hasPrevRow) {
      const prevRow = allRows[prevRowIndex];
      const prevWeights = horizontalWeights.map(w => 1 + (w - 1) * aboveVerticalFactor);
      animateItems(prevRow, prevWeights);
    }

    const activeDelta = calcMaxDelta(targetRowIndex);
    const belowDelta = hasNextRow ? calcMaxDelta(nextRowIndex) * verticalFactor : 0;
    const aboveDelta = hasPrevRow ? calcMaxDelta(prevRowIndex) * aboveVerticalFactor : 0;

    // Only animate wrappers that need to change
    allWrappers.forEach((wrp, i) => {
      // Skip wrappers that are hidden when project is open (respect computed firstVisibleIndex)


      let yPush = 0;

      if (i < targetRowIndex) {
        yPush = -activeDelta;
        // Rows above the prevRow also need to account for prevRow expansion
        if (i < prevRowIndex) {

            yPush = -aboveDelta-activeDelta

        }
      } else if (i === targetRowIndex) {

        yPush = -belowDelta;
      }

      // Only animate if value changed
      const currentY = gsap.getProperty(wrp, 'y') as number || 0;
      if (Math.abs(currentY - yPush) > 0.5) {
        gsap.to(wrp, {
          y: yPush,
          duration: DURATION,
          ease: EASE,
          overwrite: 'auto'
        });
      }
    });

    activeRowIndex = targetRowIndex;
  }

  function getAspects(row: HTMLElement): number[] {
    const items = rowItemsCache.get(row) || [];
    return items.map(item => itemAspectsCache.get(item) || 1);
  }

  function getWeights(cursorPos: number, n: number): number[] {
    return Array.from({ length: n }, (_, j) => Math.pow(FALLOFF, Math.abs(cursorPos - (j + 0.5))));
  }

  function calcBaseHeight(rowIndex: number): number {
    const width = allWrappers[rowIndex].getBoundingClientRect().width;
    const aspects = getAspects(allRows[rowIndex]);
    const n = aspects.length;
    const available = width - (n - 1) * ITEM_GAP_PX;
    const baseW = available / n;
    return Math.max(...aspects.map((a) => baseW * a));
  }

  function calcMaxDelta(rowIndex: number): number {
    const width = allWrappers[rowIndex].getBoundingClientRect().width;
    const aspects = getAspects(allRows[rowIndex]);
    const n = aspects.length;
    const available = width - (n - 1) * ITEM_GAP_PX;
    const baseH = calcBaseHeight(rowIndex);

    const samplePositions = [0, n, ...Array.from({ length: n }, (_, j) => j + 0.5)];
    let maxDelta = 0;
    for (const cursorPos of samplePositions) {
      const weights = getWeights(cursorPos, n);
      const sum = weights.reduce((a, b) => a + b, 0);
      const maxNewH = Math.max(...aspects.map((a, j) => ((available * weights[j]) / sum) * a));
      maxDelta = Math.max(maxDelta, maxNewH - baseH);
    }
    return Math.max(0, maxDelta);
  }

  function lockHeights() {
    allRows.forEach((row) => {
      row.querySelectorAll<HTMLElement>('.gallery-item').forEach((item) => {
        item.style.flexGrow = '1';
      });
    });
    allRows.forEach((row, i) => {
      allWrappers[i].style.height = `${row.getBoundingClientRect().height}px`;
    });
  }

  function fadeEdge(items: HTMLElement[]) {
    items.forEach((item) => {
      const overlay = item.querySelector('.title-fade-overlay') as HTMLElement;
      if (overlay) gsap.to(overlay, { opacity: 1, duration: DURATION_ALT, ease: EASE, overwrite: 'auto' });
    });
  }

  function restoreEdge(items: HTMLElement[]) {
    items.forEach((item) => {
      const overlay = item.querySelector('.title-fade-overlay') as HTMLElement;
      if (overlay) gsap.to(overlay, { opacity: 0, duration: DURATION_ALT, ease: EASE, overwrite: 'auto' });
    });
  }

  function updateEdgeFade(row: HTMLElement, e: MouseEvent, n: number) {
    const items = [...row.querySelectorAll<HTMLElement>('.gallery-item')];
    const previousFadedItems = fadedEdge.get(row) ?? [];

    const rect = row.getBoundingClientRect();
    const isLeftHalf = (e.clientX - rect.left) < rect.width / 2;

    const currentTargetItems: HTMLElement[] = isLeftHalf
      ? [items[n - 1], items[n - 2]].filter(Boolean)
      : [items[0], items[1]].filter(Boolean);

    const isChanged =
      currentTargetItems.length !== previousFadedItems.length ||
      currentTargetItems.some((item, i) => item !== previousFadedItems[i]);

    if (isChanged) {
      if (previousFadedItems.length > 0) restoreEdge(previousFadedItems);
      if (currentTargetItems.length > 0) fadeEdge(currentTargetItems);
      fadedEdge.set(row, currentTargetItems);
    }
  }

  function clearEdgeFade(row: HTMLElement) {
    const faded = fadedEdge.get(row);
    if (faded) {
      restoreEdge(faded);
      fadedEdge.set(row, null);
    }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // SINGLE VIEW OVERLAY LOGIC
  // ═══════════════════════════════════════════════════════════════════════════

  // ═══════════════════════════════════════════════════════════════════════════
  // SINGLE VIEW OVERLAY LOGIC
  // ═══════════════════════════════════════════════════════════════════════════

  let overlayState = {
    isOpen: false,
    projectId: null,
    currentIndex: 0,
    mediaItems: []
  };

  const overlay = document.getElementById('single-view-overlay');
  const overlayMediaContainer = document.getElementById('overlay-media-container');
  const overlayPagination = document.getElementById('overlay-pagination');
  const overlayExit = document.getElementById('overlay-exit');
  const overlayPrev = document.getElementById('overlay-prev');
  const overlayNext = document.getElementById('overlay-next');

  function buildMediaItems(project) {
    const items = [];

    // Index 0: Thumbnail
    if (project.muxID && !project.thumbnailUrl) {
      items.push({ type: 'video', playbackId: project.muxID, alt: project.name, _key: 'thumbnail' });
    } else if (project.thumbnailUrl) {
      items.push({ type: 'image', url: project.thumbnailUrl, alt: project.name, _key: 'thumbnail' });
    }

    // Index 1+: Gallery images
    if (project.galleryUrls?.length) {
      project.galleryUrls.forEach(img => {
        items.push({ type: 'image', url: img.url, alt: project.name, _key: img._key });
      });
    }

    return items;
  }

  function renderOverlayMedia() {
    if (!overlayMediaContainer) return;

    const item = overlayState.mediaItems[overlayState.currentIndex];
    if (!item) return;

    overlayMediaContainer.innerHTML = '';

    if (item.type === 'video') {
      const player = document.createElement('mux-player');
      player.setAttribute('playback-id', item.playbackId);
      player.className = 'w-full h-auto max-h-screen object-contain';
      player.setAttribute('autoplay', '');
      player.setAttribute('loop', '');
      player.setAttribute('muted', '');
      player.setAttribute('playsinline', '');
      player.style.setProperty('--controls', 'none');
      overlayMediaContainer.appendChild(player);
    } else {
      const img = document.createElement('img');
      img.src = item.url;
      img.alt = item.alt || '';
      img.className = 'w-auto h-full max-w-full max-h-screen object-contain';
      img.loading = 'eager';
      overlayMediaContainer.appendChild(img);
    }

    if (overlayPagination) {
      overlayPagination.textContent = `${overlayState.currentIndex + 1}/${overlayState.mediaItems.length}`;
    }

    // ═══════════════════════════════════════════════════════════════
    // FIX: Reset inline styles for ALL nav items to allow CSS Hovers
    // ═══════════════════════════════════════════════════════════════
    const allNavItems = [overlayExit, overlayPrev, overlayNext, overlayPagination];

    allNavItems.forEach(el => {
      if (el) {
        // 1. Clear the inline opacity left by the close animation
        el.style.opacity = '';

        // 2. Ensure pointer events are re-enabled (unless specifically disabled below)
        if (el !== overlayPrev && el !== overlayNext) {
            el.style.pointerEvents = 'auto';
        }
      }
    });

    // ═══════════════════════════════════════════════════════════════
    // FIX: Use Classes instead of Inline Styles for Disabled State
    // ═══════════════════════════════════════════════════════════════

    // Handle Previous Button
    if (overlayPrev) {
      if (overlayState.currentIndex === 0) {
        // Disabled state: Remove hover classes, add muted class
        overlayPrev.classList.remove('opacity-100', 'hover:opacity-muted');
        overlayPrev.classList.add('opacity-muted');
        overlayPrev.style.pointerEvents = 'none'; // Disable clicking
      } else {
        // Active state: Add hover classes
        overlayPrev.classList.remove('opacity-muted');
        overlayPrev.classList.add('opacity-100', 'hover:opacity-muted');
        overlayPrev.style.pointerEvents = 'auto';
      }
    }

    // Handle Next Button
    if (overlayNext) {
      if (overlayState.currentIndex === overlayState.mediaItems.length - 1) {
        // Disabled state
        overlayNext.classList.remove('opacity-100', 'hover:opacity-muted');
        overlayNext.classList.add('opacity-muted');
        overlayNext.style.pointerEvents = 'none';
      } else {
        // Active state
        overlayNext.classList.remove('opacity-muted');
        overlayNext.classList.add('opacity-100', 'hover:opacity-muted');
        overlayNext.style.pointerEvents = 'auto';
      }
    }
  }

  function openOverlay(projectId, startIndex = 0) {
    const project = getProjectById(projectId);
    if (!project || !overlay) return;

    // Pause gallery videos to avoid audio overlap
    document.querySelectorAll('mux-player').forEach(player => {
      if (player.pause) player.pause();
    });

    // Set state BEFORE animation
    overlayState.projectId = projectId;
    overlayState.mediaItems = buildMediaItems(project);
    overlayState.currentIndex = Math.max(0, Math.min(startIndex, overlayState.mediaItems.length - 1));
    overlayState.isOpen = true;

    // Prevent body scroll immediately
    document.body.style.overflow = 'hidden';

    // Show overlay container (but keep children hidden for animation)
    overlay.classList.remove('hidden');

    // Force reflow so transitions work
    void overlay.offsetHeight;

    // ═══════════════════════════════════════════════════════════════════════
    // STAGGERED ANIMATION TIMELINE
    // ═══════════════════════════════════════════════════════════════════════

    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    // Step 1: Fade in overlay background
    tl.to(overlay, {
      opacity: 1,
      duration: 0.3,
      onStart: () => {
        overlay.style.pointerEvents = 'auto';
      }
    });

    // Step 2: Render media, then fade + scale it in
    tl.call(() => {
      renderOverlayMedia();
    }, null, 0.25)
    .to('#overlay-media-container', {
      delay: 0.5,
      opacity: 1,
      duration: 0.4,
      ease: 'power2.out'
    }, 0.25);
  }

  function closeOverlay() {
    if (!overlayState.isOpen || !overlay) return;

    overlayState.isOpen = false;

    // ═══════════════════════════════════════════════════════════════════════
    // REVERSE ANIMATION TIMELINE
    // ═══════════════════════════════════════════════════════════════════════

    const tl = gsap.timeline({
      defaults: { ease: 'power3.in' },
      onComplete: () => {
        // Final cleanup after animation
        overlay.classList.add('hidden');
        overlay.style.pointerEvents = 'none';
        overlayMediaContainer.innerHTML = ''; // Clean up media
        document.body.style.overflow = ''; // Restore scroll

        // Resume gallery videos that should autoplay on hover
        document.querySelectorAll('.gallery-item mux-player').forEach(player => {
          if (player.play && player.closest('.gallery-item:hover')) {
            player.play();
          }
        });
      }
    });

    // Step 1: Fade out navigation items (reverse stagger)
    const navItems = [
      overlayExit, overlayPrev, overlayNext, overlayPagination
    ].filter(el => el);

    tl.to(navItems, {
      opacity: 0,

      duration: 0.25,
      stagger: {
        each: 0.05,
        from: 'end', // Right to left on close
        ease: 'power2.in'
      },

    });

    // Step 2: Fade + scale out media (0.15s after nav starts)
    tl.to('#overlay-media-container', {
      opacity: 0,
      duration: 0.3
    }, 0.15);

    // Step 3: Fade out overlay background (last)
    tl.to(overlay, {
      opacity: 0,
      duration: 0.6,
      ease: 'power2.out'
    });
  }

  function nextMedia() {
    if (overlayState.currentIndex < overlayState.mediaItems.length - 1) {
      overlayState.currentIndex++;
      renderOverlayMedia();
    }
  }

  function prevMedia() {
    if (overlayState.currentIndex > 0) {
      overlayState.currentIndex--;
      renderOverlayMedia();
    }
  }

  // ─── Overlay Control Event Listeners ─────────────────────────────────────
  if (overlayExit) {
    overlayExit.addEventListener('click', (e) => {
      e.preventDefault();
      closeOverlay();
    });
  }

  if (overlayNext) {
    overlayNext.addEventListener('click', (e) => {
      e.preventDefault();
      nextMedia();
    });
  }

  if (overlayPrev) {
    overlayPrev.addEventListener('click', (e) => {
      e.preventDefault();
      prevMedia();
    });
  }

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (!overlayState.isOpen) return;

    if (e.key === 'Escape') {
      e.preventDefault();
      closeOverlay();
    } else if (e.key === 'ArrowRight') {
      e.preventDefault();
      nextMedia();
    } else if (e.key === 'ArrowLeft') {
      e.preventDefault();
      prevMedia();
    }
  });

  // Click outside media to close
  if (overlay) {
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        closeOverlay();
      }
    });
  }

  // ─── Attach Click Handlers to Detail Gallery Images ──────────────────────
  let detailGalleryListenerAttached = false; // ← Prevent duplicate listeners

  function attachDetailGalleryListeners() {
    if (!detailImageGallery || detailGalleryListenerAttached) return;

    detailGalleryListenerAttached = true; // ← Mark as attached

    // Use event delegation on the container
    detailImageGallery.addEventListener('click', (e) => {
      // Find the clicked slot
      const slot = e.target.closest('#detail-first-image, .col-span-1.w-full.overflow-hidden');
      if (!slot) return; // ← Removed: || !overlayState.isOpen

      e.preventDefault();
      e.stopPropagation();

      const projectId = currentProjectId;
      if (!projectId) {
        console.warn('No currentProjectId found');
        return;
      }

      // Get project data
      const project = getProjectById(projectId);
      if (!project) return;

      // Build media items array (same as overlay logic)
      const mediaItems = [];
      if (project.muxID && !project.thumbnailUrl) {
        mediaItems.push({ type: 'video', playbackId: project.muxID, _key: 'thumbnail' });
      } else if (project.thumbnailUrl) {
        mediaItems.push({ type: 'image', url: project.thumbnailUrl, _key: 'thumbnail' });
      }
      if (project.galleryUrls?.length) {
        project.galleryUrls.forEach(img => {
          mediaItems.push({ type: 'image', url: img.url, _key: img._key });
        });
      }

      // Determine clicked index
      let clickedIndex = 0;
      if (slot.id !== 'detail-first-image') {
        const slots = [...detailImageGallery.querySelectorAll('#detail-first-image, .col-span-1.w-full.overflow-hidden')];
        clickedIndex = Math.max(0, slots.indexOf(slot));
      }

      // ← OPEN the overlay (this was the main bug!)
      openOverlay(projectId, clickedIndex);
    }, { once: false }); // ← Ensure listener persists
  }

  function animateItems(row: HTMLElement, weights: number[]) {
    // Generate a key for this weight configuration to avoid redundant animations
    const weightsKey = `${allRows.indexOf(row)}-${weights.map(w => w.toFixed(2)).join(',')}`;
    if (weightsKey === lastWeightsKey && allRows.indexOf(row) === lastTargetRowIndex) {
      return; // Skip if same animation
    }
    lastWeightsKey = weightsKey;
    lastTargetRowIndex = allRows.indexOf(row);

    const items = rowItemsCache.get(row) || [];
    items.forEach((item, j) => {
      // Use gsap.to directly with overwrite instead of creating timelines
      gsap.to(item, {
        flexGrow: weights[j],
        duration: DURATION_ALT,
        ease: EASE,
        overwrite: true,
      });
    });
  }

  function resetRow(row: HTMLElement) {
    const items = rowItemsCache.get(row) || [];
    items.forEach((item) => {
      gsap.to(item, { flexGrow: 1, duration: DURATION_ALT, ease: EASE, overwrite: true });
    });
    clearEdgeFade(row);
    gsap.set(row, { zIndex: 'auto' });
  }

  // ─── Init ──────────────────────────────────────────────────────────────────

  function init() {
    try {
      if (allWrappers.length === 0 || allRows.length === 0) {
        console.warn('No gallery rows found');
        return;
      }

      lockHeights();

      const deltas = allWrappers.map((_, i) => calcMaxDelta(i)).filter(d => isFinite(d) && !isNaN(d));
      const maxDelta = deltas.length > 0 ? Math.max(...deltas) : 0;
      gsap.set(container, { y: maxDelta + 20 });

      container.querySelectorAll<HTMLElement>('.gallery-item').forEach((item) => {
        const video = item.querySelector('mux-player') as (HTMLVideoElement & { play: () => void; pause: () => void }) | null;
        if (!video) return;
        item.addEventListener('mouseenter', () => video.play());
        item.addEventListener('mouseleave', () => video.pause());
      });
    } catch (e) {
      console.error('Error initializing gallery:', e);
    }
  }

  // Wait for DOM to be ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // Debounced resize handler
  let resizeTimeout: ReturnType<typeof setTimeout> | null = null;
  window.addEventListener('resize', () => {
    if (resizeTimeout) clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      // Reset weight tracking caches on resize (layout changed)
      lastWeightsKey = '';
      lastTargetRowIndex = -1;

      if (!isProjectOpen) {
        init();
      }
    }, 150); // 150ms debounce
  });

  // ─── Theme Change Listener ─────────────────────────────────────────────────
  window.addEventListener('themechange', () => {
    const newOpacity = getMutedOpacity();

    // Update sidebar list items (non-active ones)
    document.querySelectorAll('.detail-list-item').forEach(item => {
      const itemId = (item as HTMLElement).dataset.projectId;
      if (itemId !== currentProjectId) {
        gsap.to(item, { opacity: newOpacity});
      }
    });

    // Update project type opacity
    if (detailProjectType && isProjectOpen) {
      gsap.to(detailProjectType, { opacity: newOpacity });
    }
  });

  } // End of else block for DOM element check


</script>
