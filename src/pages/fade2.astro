---
import Layout from '../layouts/Layout.astro';

import { MuxPlayer } from '@mux/mux-player-astro';
import { loadQuery } from '../sanity/lib/loadQuery.ts';
import { urlForImage } from '../sanity/lib/url-for-image.ts';

import { sanityClient } from 'sanity:client';

const PROJECTS_QUERY = `*[_type == "project"] | order(index desc) {
 _id,
  name,
  type,
  index,
  thumbnail,
  imageGallery,
  muxID,
}`;

const { data: projects } = await loadQuery({ query: PROJECTS_QUERY });
console.log('projects:', projects);

const ROW_SIZE = 5;

// Chunk into rows of ROW_SIZE
const rows = Array.from({ length: Math.ceil(projects.length / ROW_SIZE) }, (_, i) =>
  projects.slice(i * ROW_SIZE, i * ROW_SIZE + ROW_SIZE)
);

// aspect is h/w — portrait 2/3 = 1.5, landscape 16/9 ≈ 0.5625
function getAspect(project: (typeof projects)[number]): number {
  return project.muxID && !project.thumbnail?.asset ? 9 / 16 : 7 / 5;
}


---

<Layout>
  <main class="p-1.5 bg-white text-black">
    <section class="">
      {projects.length === 0 && <p class="text-gray-400">No projects found.</p>}

      <div id="gallery-container" class="flex flex-col gap-0">
        {
          rows.map((row, rowIndex) => (
            <div class="gallery-row-wrapper relative" data-wrapper={rowIndex}>
              <div
                class="gallery-row absolute inset-x-0 bottom-0 flex gap-1.5 items-end pt-5"
                data-row={rowIndex}
              >
                {row.map((project, projectIndex) => {
                  const aspect = getAspect(project);
                  const globalIndex = rowIndex * ROW_SIZE + projectIndex;
                  return (
                    <div
                      class="gallery-item flex flex-col gap-1.5 min-w-0"
                      style="flex: 1 1 0%"
                      data-aspect={aspect}
                      data-row={rowIndex}
                      data-global-index={globalIndex}
                    >
                      {project.muxID && !project.thumbnail?.asset ? (
                        <MuxPlayer
                          playbackId={project.muxID}
                          class="item-media w-full object-cover aspect-16/9"
                          style={{ '--controls': 'none' }}
                          muted
                          loop
                        />
                      ) : (
                        <img
                        src={`${urlForImage(project.thumbnail).url()}?auto=format`}
                          alt={project.name}
                          class="item-media w-full object-cover"
                          style="aspect-ratio: 5/7"
                        />
                      )}
                      <div class="item-name-type flex flex-row justify-between w-full relative overflow-clip">
                        <div class="absolute z-0 mt-0 h-full flex flex-col gap-0 z-project-title">
                          <h3 class="text-sm leading-[100%] tracking-[-1%] whitespace-nowrap">{project.name}</h3>
                        </div>
                        <div class="title-fade-overlay absolute inset-0 h-full w-full z-1 pointer-events-none opacity-0 bg-[linear-gradient(to_left,rgba(255,255,255,1)_5%,rgba(255,255,255,0.2)_40%)]"></div>
                        <div class="flex flex-col gap-0 items-end grow z-2">
                          <p class="text-sm leading-[100%] tracking-[-1%] flex">{project.index}</p>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
<script>
  import gsap from 'gsap';

  const FALLOFF = 0.65;
  const ITEM_GAP_PX = 5;
  const DURATION = 0.9;
  const DURATION_ALT = 0.6;
  const EASE = 'power3.out';

  const container = document.getElementById('gallery-container')!;
  const allWrappers = [...container.querySelectorAll<HTMLElement>('.gallery-row-wrapper')];
  const allRows = [...container.querySelectorAll<HTMLElement>('.gallery-row')];

  let activeRow: HTMLElement | null = null;
  let activeRowIndex: number = -1;
  let leaveTimer: ReturnType<typeof gsap.delayedCall> | null = null;

  const fadedEdge = new Map<HTMLElement, HTMLElement[] | null>();
  const itemTimelines = new Map<HTMLElement, gsap.core.Timeline>();
  let lastMouseX = 0;
  let lastMouseY = 0;

  window.addEventListener('mousemove', (e) => {
    lastMouseX = e.clientX;
    lastMouseY = e.clientY;
  });

  function updateHoverAtPoint(clientX: number, clientY: number) {
    let targetWrapperIndex = -1;

    // Find which wrapper the cursor is currently over
    for (let i = 0; i < allWrappers.length; i++) {
      const rect = allWrappers[i].getBoundingClientRect();
      if (
        clientY >= rect.top &&
        clientY <= rect.bottom &&
        clientX >= rect.left &&
        clientX <= rect.right
      ) {
        targetWrapperIndex = i;
        break;
      }
    }

    if (targetWrapperIndex === -1) return;

    const targetRowIndex = getTargetRowIndex(targetWrapperIndex, clientY);
    activateRowAt(targetRowIndex);

    const targetRow = allRows[targetRowIndex];
    const items = [...targetRow.querySelectorAll<HTMLElement>('.gallery-item')];
    const n = items.length;
    const rect = targetRow.getBoundingClientRect();
    const cursorPos = ((clientX - rect.left) / rect.width) * n;

    animateItems(targetRow, getWeights(cursorPos, n));
    updateEdgeFade(targetRow, { clientX, clientY } as MouseEvent, n);
  };
  function getAspects(row: HTMLElement): number[] {
    return [...row.querySelectorAll<HTMLElement>('.gallery-item')].map((item) =>
      parseFloat(item.dataset.aspect!)
    );
  }

  function getWeights(cursorPos: number, n: number): number[] {
    return Array.from({ length: n }, (_, j) => Math.pow(FALLOFF, Math.abs(cursorPos - (j + 0.5))));
  }

  function calcBaseHeight(rowIndex: number): number {
    const width = allWrappers[rowIndex].getBoundingClientRect().width;
    const aspects = getAspects(allRows[rowIndex]);
    const n = aspects.length;
    const available = width - (n - 1) * ITEM_GAP_PX;
    const baseW = available / n;
    return Math.max(...aspects.map((a) => baseW * a));
  }

  function calcMaxDelta(rowIndex: number): number {
    const width = allWrappers[rowIndex].getBoundingClientRect().width;
    const aspects = getAspects(allRows[rowIndex]);
    const n = aspects.length;
    const available = width - (n - 1) * ITEM_GAP_PX;
    const baseH = calcBaseHeight(rowIndex);

    const samplePositions = [0, n, ...Array.from({ length: n }, (_, j) => j + 0.5)];
    let maxDelta = 0;
    for (const cursorPos of samplePositions) {
      const weights = getWeights(cursorPos, n);
      const sum = weights.reduce((a, b) => a + b, 0);
      const maxNewH = Math.max(...aspects.map((a, j) => ((available * weights[j]) / sum) * a));
      maxDelta = Math.max(maxDelta, maxNewH - baseH);
    }
    return Math.max(0, maxDelta);
  }

  function lockHeights() {
    allRows.forEach((row) => {
      row.querySelectorAll<HTMLElement>('.gallery-item').forEach((item) => {
        item.style.flexGrow = '1';
      });
    });
    allRows.forEach((row, i) => {
      allWrappers[i].style.height = `${row.getBoundingClientRect().height}px`;
    });
  }

  // ─── Edge fade ─────────────────────────────────────────────────────────────

  function fadeEdge(items: HTMLElement[]) {
    items.forEach((item) => {
      const overlay = item.querySelector('.title-fade-overlay') as HTMLElement;
      if (overlay) gsap.to(overlay, { opacity: 1, duration: DURATION_ALT, ease: EASE, overwrite: 'auto' });
    });
  }

  function restoreEdge(items: HTMLElement[]) {
    items.forEach((item) => {
      const overlay = item.querySelector('.title-fade-overlay') as HTMLElement;
      if (overlay) gsap.to(overlay, { opacity: 0, duration: DURATION_ALT, ease: EASE, overwrite: 'auto' });
    });
  }

  function updateEdgeFade(row: HTMLElement, e: MouseEvent, n: number) {
    const items = [...row.querySelectorAll<HTMLElement>('.gallery-item')];
    const previousFadedItems = fadedEdge.get(row) ?? [];

    const rect = row.getBoundingClientRect();
    const isLeftHalf = (e.clientX - rect.left) < rect.width / 2;

    const currentTargetItems: HTMLElement[] = isLeftHalf
      ? [items[n - 1], items[n - 2]].filter(Boolean)
      : [items[0], items[1]].filter(Boolean);

    const isChanged =
      currentTargetItems.length !== previousFadedItems.length ||
      currentTargetItems.some((item, i) => item !== previousFadedItems[i]);

    if (isChanged) {
      if (previousFadedItems.length > 0) restoreEdge(previousFadedItems);
      if (currentTargetItems.length > 0) fadeEdge(currentTargetItems);
      fadedEdge.set(row, currentTargetItems);
    }
  }

  function clearEdgeFade(row: HTMLElement) {
    const faded = fadedEdge.get(row);
    if (faded) {
      restoreEdge(faded);
      fadedEdge.set(row, null);
    }
  }

  // ─── Animation ─────────────────────────────────────────────────────────────

  function animateItems(row: HTMLElement, weights: number[]) {
    row.querySelectorAll<HTMLElement>('.gallery-item').forEach((item, j) => {
      // Kill existing timeline for this item
      const existing = itemTimelines.get(item);
      if (existing) existing.kill();

      // Create instant timeline
      const tl = gsap.timeline();
      tl.to(item, {
        flexGrow: weights[j],
        duration: DURATION_ALT,
        ease: EASE,
        overwrite: true,
      });
      itemTimelines.set(item, tl);
    });
  }

  function resetRow(row: HTMLElement) {
    row.querySelectorAll<HTMLElement>('.gallery-item').forEach((item) => {
      // Kill existing timeline
      const existing = itemTimelines.get(item);
      if (existing) existing.kill();

      const tl = gsap.timeline();
      tl.to(item, { flexGrow: 1, duration: DURATION_ALT, ease: EASE, overwrite: true });
      itemTimelines.set(item, tl);
    });
    clearEdgeFade(row);
    gsap.set(row, { zIndex: 'auto' });
  }

  function pushAbove(rowIndex: number, delta: number) {
    allWrappers.forEach((wrapper, i) => {
      gsap.to(wrapper, {
        y: i < rowIndex ? -delta : 0,
        duration: DURATION,
        ease: EASE,
        overwrite: 'auto',
      });
    });
  }

  function resetAbove() {
    allWrappers.forEach((wrapper) => {
      gsap.to(wrapper, { y: 0, duration: DURATION, ease: EASE, overwrite: 'auto' });
    });
  }

  // ─── Routing helpers ───────────────────────────────────────────────────────

  // If the cursor is above the actual row element (i.e. in the white space at
  // the top of this wrapper), redirect to the row above so hovering upward
  // into the gap feels continuous rather than dead.
  function getTargetRowIndex(wrapperIndex: number, clientY: number): number {
    if (wrapperIndex > 0) {
      const rowRect = allRows[wrapperIndex].getBoundingClientRect();
      if (clientY < rowRect.top) return wrapperIndex - 1;
    }
    return wrapperIndex;
  }

  function activateRowAt(rowIndex: number) {
    const row = allRows[rowIndex];
    if (activeRow === row) return;

    if (activeRow) resetRow(activeRow);
    activeRow = row;
    activeRowIndex = rowIndex;
    gsap.set(row, { zIndex: 10 });
    pushAbove(rowIndex, calcMaxDelta(rowIndex));
  }

  // ─── Events ────────────────────────────────────────────────────────────────

  allWrappers.forEach((wrapper, wrapperIndex) => {
    wrapper.addEventListener('mousemove', (e: MouseEvent) => {
      leaveTimer?.kill();
      leaveTimer = null;

      updateHoverAtPoint(e.clientX, e.clientY);
    });
    window.addEventListener('scroll', () => {
      if (lastMouseX === 0 && lastMouseY === 0) return;
      updateHoverAtPoint(lastMouseX, lastMouseY);
    }, { passive: true });

    wrapper.addEventListener('mouseleave', () => {
      if (activeRow) resetRow(activeRow);
      activeRow = null;
      activeRowIndex = -1;
      resetAbove();

    });
  });

  // ─── Init ──────────────────────────────────────────────────────────────────

  function init() {
    lockHeights();

    const maxDelta = Math.max(...allWrappers.map((_, i) => calcMaxDelta(i)));
    gsap.set(container, { y: maxDelta + 20 });

    container.querySelectorAll<HTMLElement>('.gallery-item').forEach((item) => {
      const video = item.querySelector('mux-player') as (HTMLVideoElement & { play: () => void; pause: () => void }) | null;
      if (!video) return;
      item.addEventListener('mouseenter', () => video.play());
      item.addEventListener('mouseleave', () => video.pause());
    });
  }

  init();
  window.addEventListener('resize', init);

</script>
